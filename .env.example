# OpenDART API 키
# https://opendart.fss.or.kr/에서 발급받은 키를 입력하세요
DART_API_KEY=your_api_key_here
# 대상 회사
TARGET_STOCK_CODE=005930
TARGET_COMPANY_NAME=삼성전자

# 보고서 설정
TARGET_REPORT_CODE=11011
TARGET_REPORT_TYPE=사업보고서
TARGET_FS_DIV=CFS

# 조회 기간 (년도, 콤마로 구분)
TARGET_YEARS=2023,2022,2021,2020,2019

# 데이터 저장 경로
DATA_RAW_PATH=data/raw
DATA_INTERIM_PATH=data/interim
DATA_PROCESSED_PATH=data/processed
